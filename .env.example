# --- OpenRouter / OCR ---
# Required for OCR requests
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-vl-32b-instruct

# --- Ollama / embeddings ---
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# --- OCR + chunking runtime ---
RENDER_DPI=150
OCR_TIMEOUT_S=300
OCR_WORKERS=5
OCR_RETRIES=3
CHUNK_CHARS=1500
CHUNK_OVERLAP=200
EMBED_TIMEOUT_S=120
TEXT_OUT_DIR=ocr_texts

# --- Postgres ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ethics
# Defaults to current OS user if unset in the script, but setting explicitly is recommended.
DB_USER=
DB_PASSWORD=